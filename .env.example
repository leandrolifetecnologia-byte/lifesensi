# Copie para .env (local) e/ou configure em Site settings > Environment variables na Netlify.
# NUNCA versione o .env real.

# Credenciais de uma conta de serviço do Metam (recomendo criar um usuário
# dedicado só-leitura, não usar a conta pessoal do Leandro).
METAM_EMAIL=
METAM_PASSWORD=

# Dispositivos que a página pode consultar (allowlist, separados por vírgula).
# 71987 = Energia (Sala de TI) · 71705 = Entrada Principal · 71961 = Água (Reservatório)
METAM_LOCATION_IDS=71987,71961,71705
# Dashboard usado pela aba Água (widgets de Consumo/Vazão).
METAM_SUPERVISORY_ID=1940
